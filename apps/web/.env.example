# Environment Variables
# Copy this file to .env and fill in the values

# Deployed ERC721 NFT address
NEXT_PUBLIC_NFT_ADDRESS=

# URL of the ERC721 deployment API
ERC721_DEPLOYMENT_API_URL=http://localhost:4001

# Name of the AI agent (required)
AGENT_NAME=MyAgent

# OpenRouter API key for LLM access (required) [secret]
OPENROUTER_API_KEY=

# Model to use via OpenRouter
OPENROUTER_MODEL=openai/gpt-4o

# ERC-8004 registry contract address
NEXT_PUBLIC_AGENT_REGISTRY_ADDRESS=

# Agent wallet private key for registry operations [secret]
AGENT_PRIVATE_KEY=

# Network for agent operations (arbitrum or arbitrum-sepolia) (required)
NEXT_PUBLIC_AGENT_NETWORK=arbitrum

# WalletConnect Cloud project ID for wallet connections (required)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Application name displayed in wallet dialogs
NEXT_PUBLIC_APP_NAME=My DApp